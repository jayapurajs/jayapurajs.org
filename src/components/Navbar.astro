---
import { useTranslations } from '@/i18n/translations';

const lang = (Astro.currentLocale ?? 'id') as 'id' | 'en';
const t = useTranslations(lang);
const base = lang === 'en' ? '/en' : '';
const rawPath = Astro.url.pathname;
const altLangHref = lang === 'id'
  ? `/en${rawPath}`
  : rawPath.replace(/^\/en/, '') || '/';
---

<header
  id="page-header"
  x-data="{
    mobileNavOpen: false,
    isScrolled: false,
    currentPath: window.location.pathname,
    isActive(segment) {
      const p = this.currentPath;
      const norm = (p === '/en' || p === '/en/') ? '/' : p.startsWith('/en/') ? p.slice(3) : p;
      return segment === '/' ? (norm === '/' || norm === '') : norm.startsWith(segment);
    },
    closeMobileNav() { this.mobileNavOpen = false; }
  }"
  x-init="
    window.addEventListener('scroll', () => { isScrolled = window.scrollY > 10 });
    document.addEventListener('astro:after-navigation', () => {
      currentPath = window.location.pathname;
      mobileNavOpen = false;
    });
    $watch('mobileNavOpen', value => {
      document.body.style.overflow = value ? 'hidden' : 'auto'
    });
  "
  @keydown.escape.window="closeMobileNav"
  :class="isScrolled ? 'border-b border-neutral-200' : ''"
  class="fixed top-0 left-0 right-0 z-50 w-full bg-white py-3"
>
  <div class="mx-auto max-w-[85rem] w-full px-4 sm:px-6 lg:px-8">
    <!-- Main navigation -->
    <nav class="flex items-center justify-between gap-3">
      <!-- Logo -->
      <a
        href={`${base}/`}
        class="flex items-center group transition-all active:scale-95 outline-none"
      >
        <div class="relative h-10 md:h-12 flex items-center">
          <img
            src="/images/logo/jayapurajs-light-transparent.png"
            class="h-36 w-36"
            alt="Jayapura JavaScript"
          />
        </div>
      </a>

      <!-- Desktop navigation -->
      <div class="hidden md:flex items-center gap-5">
        <a
          href={`${base}/`}
          :class="isActive('/') ? 'border-b-2 border-yellow-500 text-yellow-500' : 'text-neutral-600 hover:text-yellow-500'"
          class="px-1 py-2 text-sm font-medium"
        >{t('nav_home')}</a>
        <a
          href={`${base}/events`}
          :class="isActive('/events') ? 'border-b-2 border-yellow-500 text-yellow-500' : 'text-neutral-600 hover:text-yellow-500'"
          class="px-1 py-2 text-sm font-medium"
        >{t('nav_events')}</a>
        <a
          href={`${base}/about`}
          :class="isActive('/about') ? 'border-b-2 border-yellow-500 text-yellow-500' : 'text-neutral-600 hover:text-yellow-500'"
          class="px-1 py-2 text-sm font-medium"
        >{t('nav_about')}</a>
        <a
          href={`${base}/coc`}
          :class="isActive('/coc') ? 'border-b-2 border-yellow-500 text-yellow-500' : 'text-neutral-600 hover:text-yellow-500'"
          class="px-1 py-2 text-sm font-medium"
        >{t('nav_coc')}</a>

        <!-- Language switcher -->
        <div class="flex items-center border border-neutral-200 rounded-lg overflow-hidden text-xs font-bold">
          <a
            href={lang === 'en' ? altLangHref : rawPath}
            class={`px-2.5 py-1.5 transition-colors ${lang === 'id' ? 'bg-yellow-400 text-neutral-900' : 'text-neutral-500 hover:text-neutral-900'}`}
          >ID</a>
          <a
            href={lang === 'id' ? altLangHref : rawPath}
            class={`px-2.5 py-1.5 transition-colors ${lang === 'en' ? 'bg-yellow-400 text-neutral-900' : 'text-neutral-500 hover:text-neutral-900'}`}
          >EN</a>
        </div>
      </div>

      <!-- Mobile menu button -->
      <button
        @click="mobileNavOpen = !mobileNavOpen"
        type="button"
        class="md:hidden p-2 rounded-lg border border-neutral-200 text-neutral-800 hover:bg-neutral-50 transition-all active:scale-90"
        aria-label="Toggle menu"
        :aria-expanded="mobileNavOpen"
      >
        <svg x-show="!mobileNavOpen" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg x-show="mobileNavOpen" x-cloak class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </nav>

    <!-- Mobile dropdown -->
    <div
      x-show="mobileNavOpen"
      x-cloak
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 -translate-y-2"
      x-transition:enter-end="opacity-100 translate-y-0"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="opacity-100 translate-y-0"
      x-transition:leave-end="opacity-0 -translate-y-2"
      class="md:hidden absolute left-0 right-0 top-full mt-2 mx-4 bg-white rounded-xl border border-neutral-200 overflow-hidden"
    >
      <nav class="flex flex-col p-2 text-sm">
        <a href={`${base}/`} @click="closeMobileNav" :class="isActive('/') ? 'border-l-4 border-yellow-500 text-yellow-700' : 'text-neutral-700 hover:text-yellow-500'" class="flex items-center gap-3 px-4 py-3">
          <span>{t('nav_home')}</span>
        </a>
        <a href={`${base}/events`} @click="closeMobileNav" :class="isActive('/events') ? 'border-l-4 border-yellow-500 text-yellow-700' : 'text-neutral-700 hover:text-yellow-500'" class="flex items-center gap-3 px-4 py-3">
          <span>{t('nav_events')}</span>
        </a>
        <a href={`${base}/about`} @click="closeMobileNav" :class="isActive('/about') ? 'border-l-4 border-yellow-500 text-yellow-700' : 'text-neutral-700 hover:text-yellow-500'" class="flex items-center gap-3 px-4 py-3">
          <span>{t('nav_about')}</span>
        </a>
        <a href={`${base}/coc`} @click="closeMobileNav" :class="isActive('/coc') ? 'border-l-4 border-yellow-500 text-yellow-700' : 'text-neutral-700 hover:text-yellow-500'" class="flex items-center gap-3 px-4 py-3">
          <span>{t('nav_coc')}</span>
        </a>
        <!-- Language switcher in mobile -->
        <div class="flex items-center gap-2 px-4 py-3 border-t border-neutral-100 mt-1">
          <span class="text-xs text-neutral-400 font-medium">{t('nav_lang_label')}</span>
          <div class="flex items-center border border-neutral-200 rounded-lg overflow-hidden text-xs font-bold">
            <a href={lang === 'en' ? altLangHref : rawPath} class={`px-2.5 py-1 transition-colors ${lang === 'id' ? 'bg-yellow-400 text-neutral-900' : 'text-neutral-500'}`}>ID</a>
            <a href={lang === 'id' ? altLangHref : rawPath} class={`px-2.5 py-1 transition-colors ${lang === 'en' ? 'bg-yellow-400 text-neutral-900' : 'text-neutral-500'}`}>EN</a>
          </div>
        </div>
      </nav>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-20 md:h-24"></div>
